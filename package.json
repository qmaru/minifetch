{
  "name": "@qmaru/minifetch",
  "version": "1.0.0",
  "description": "A minimal, modern fetch wrapper",
  "author": "qmaru",
  "license": "ISC",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./package.json": "./package.json"
  },
  "types": "dist/index.d.mts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest test",
    "lint": "oxlint",
    "fmt": "oxfmt"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qmaru/minifetch.git"
  },
  "homepage": "https://github.com/qmaru/minifetch#readme",
  "publishConfig": {
    "@qmaru:registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
{
  "compilerOptions": {
    // user
    "paths": {
      "@/*": [
        "./src/*"
      ],
    },
    "outDir": "dist",
    // output
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // types
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": [
      "vitest/globals"
    ],
    // strict
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // ts
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "src",
    "tests"
  ]
}
{
  "compilerOptions": {
    // user
    "paths": {
      "@/*": [
        "./src/*"
      ],
    },
    "outDir": "dist",
    "rootDir": "src",
    // output
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // types
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    // strict
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // ts
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "tests"
  ]
}